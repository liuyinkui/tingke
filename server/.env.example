# 听刻 后端服务 — 环境变量配置

# 服务端口
PORT=3000

# 环境 (development | production)
NODE_ENV=development

# PostgreSQL 数据库
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tingke_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Redis 缓存
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 密钥（生产环境请替换为强随机字符串）
JWT_SECRET=change-me-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=7d

# CORS 允许的域名（逗号分隔）
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# 阿里云 OSS（素材音频存储）
OSS_REGION=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# 阿里云腾讯云 语音评测
SPEECH_EVALUATION_PROVIDER=
SPEECH_EVALUATION_APP_ID=
SPEECH_EVALUATION_SECRET=
